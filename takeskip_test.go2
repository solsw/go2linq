func Test_TakeWhileMust(t *testing.T) {
	type args struct {
		pred common.Predicate
	}
	tests := []struct {
		name string
		source Enumerator[int]
		args args
		want Enumerator[int]
	}{
		{name: "PredicateFailingFirstElement",
			source: NewOnSlice("zero", "one", "two", "three", "four", "five", "six"),
			args: args{pred: func(e common.Elem) bool { return len(e.(string)) > 4 }},
			want: enEmpty},
		{name: "PredicateMatchingSomeElements",
			source: NewOnSlice("zero", "one", "two", "three", "four", "five"),
			args: args{pred: func(e common.Elem) bool { return len(e.(string)) < 5 }},
			want: NewOnSlice("zero", "one", "two")},
		{name: "PredicateMatchingAllElements",
			source: NewOnSlice("zero", "one", "two", "three", "four", "five"),
			args: args{pred: func(e common.Elem) bool { return len(e.(string)) < 100 }},
			want: NewOnSlice("zero", "one", "two", "three", "four", "five")},
	}
	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			if got := tt.source.TakeWhileMust(tt.args.pred); !SequenceEqualMust(got, tt.want) {
				got.Reset()
				tt.want.Reset()
				t.Errorf("TakeWhileMust() = '%v', want '%v'", String(got), String(tt.want))
			}
		})
	}
}

func Test_TakeWhileIdxMust(t *testing.T) {
	type args struct {
		pred common.PredicateIdx
	}
	tests := []struct {
		name string
		source Enumerator[int]
		args args
		want Enumerator[int]
	}{
		{name: "PredicateWithIndexFailingFirstElement",
			source: NewOnSlice("zero", "one", "two", "three", "four", "five"),
			args: args{pred: func(e common.Elem, i int) bool { return i+len(e.(string)) > 4 }},
			want: enEmpty},
		{name: "PredicateWithIndexMatchingSomeElements",
			source: NewOnSlice("zero", "one", "two", "three", "four", "five"),
			args: args{pred: func(e common.Elem, i int) bool { return len(e.(string)) != i }},
			want: NewOnSlice("zero", "one", "two", "three")},
		{name: "PredicateWithIndexMatchingAllElements",
			source: NewOnSlice("zero", "one", "two", "three", "four", "five"),
			args: args{pred: func(e common.Elem, i int) bool { return len(e.(string)) < 100 }},
			want: NewOnSlice("zero", "one", "two", "three", "four", "five")},
	}
	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			if got := tt.source.TakeWhileIdxMust(tt.args.pred); !SequenceEqualMust(got, tt.want) {
				got.Reset()
				tt.want.Reset()
				t.Errorf("TakeWhileIdxMust() = '%v', want '%v'", String(got), String(tt.want))
			}
		})
	}
}

