package go2linq

import (
	"strings"
	"testing"
)

// https://github.com/jskeet/edulinq/blob/master/src/Edulinq.Tests/WhereTest.cs

func Test_Where_int(t *testing.T) {
	type args struct {
		predicate func(int) bool
	}
	tests := []struct {
		name string
		source Enumerator[int]
		args args
		want Enumerator[int]
		wantErr bool
		expectedErr error
	}{
		{name: "NullSourceThrowsNullArgumentException",
			source: nil,
			args: args{predicate: func(i int) bool { return i > 5 }},
			wantErr: true,
			expectedErr: ErrNilSource,
		},
		{name: "NullPredicateThrowsNullArgumentException",
			source: NewOnSlice(1, 2, 3, 4),
			args: args{predicate: nil},
			wantErr: true,
			expectedErr: ErrNilPredicate,
		},
		{name: "SimpleFiltering",
			source: NewOnSlice(1, 3, 4, 2, 8, 1),
			args: args{predicate: func(i int) bool { return i < 4 }},
			want: NewOnSlice(1, 3, 2, 1),
		},
		{name: "EmptySource",
			source: Empty[int](),
			args: args{predicate: func(i int) bool { return i > 5 }},
			want: Empty[int](),
		},
	}
	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			got, err := Where(tt.source, tt.args.predicate)
			if (err != nil) != tt.wantErr {
				t.Errorf("Where() error = '%v', wantErr '%v'", err, tt.wantErr)
				return
			}
			if tt.wantErr {
				if err != tt.expectedErr {
					t.Errorf("Where() error = '%v', expectedErr '%v'", err, tt.expectedErr)
				}
				return
			}
			if !SequenceEqualMust(got, tt.want) {
				got.Reset()
				tt.want.Reset()
				t.Errorf("Where() = '%v', want '%v'", String(got), String(tt.want))
			}
		})
	}
}

func Test_WhereMust_int(t *testing.T) {
	type args struct {
		predicate func(int) bool
	}
	tests := []struct {
		name string
		source Enumerator[int]
		args args
		want Enumerator[int]
	}{
		{name: "1",
			source: NewOnSlice(1, 2, 3, 4),
			args: args{predicate: func(int) bool { return false }},
			want: Empty[int](),
		},
		{name: "2",
			source: NewOnSlice(1, 2, 3, 4),
			args: args{predicate: func(int) bool { return true }},
			want: NewOnSlice(1, 2, 3, 4),
		},
		{name: "3",
			source: NewOnSlice(1, 2, 3, 4),
			args: args{predicate: func(i int) bool { return i%2 == 1 }},
			want: NewOnSlice(1, 3),
		},
	}
	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			if got := WhereMust(tt.source, tt.args.predicate); !SequenceEqualMust(got, tt.want) {
				got.Reset()
				tt.want.Reset()
				t.Errorf("WhereMust() = '%v', want '%v'", String(got), String(tt.want))
			}
		})
	}
}

func Test_WhereMust_string(t *testing.T) {
	type args struct {
		predicate func(string) bool
	}
	tests := []struct {
		name string
		source Enumerator[string]
		args args
		want Enumerator[string]
	}{
		{name: "4",
			source: NewOnSlice("one", "two", "three", "four", "five"),
			args: args{predicate: func(string) bool { return true }},
			want: NewOnSlice("one", "two", "three", "four", "five"),
		},
		{name: "5", source: NewOnSlice("one", "two", "three", "four", "five"),
			args: args{predicate: func(s string) bool { return strings.HasPrefix(s, "t") }},
			want: NewOnSlice("two", "three"),
		},
	}
	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			if got := WhereMust(tt.source, tt.args.predicate); !SequenceEqualMust(got, tt.want) {
				got.Reset()
				tt.want.Reset()
				t.Errorf("WhereMust() = '%v', want '%v'", String(got), String(tt.want))
			}
		})
	}
}

func Test_WhereIdx_int(t *testing.T) {
	type args struct {
		predicate func(int, int) bool
	}
	tests := []struct {
		name string
		source Enumerator[int]
		args args
		want Enumerator[int]
		wantErr bool
		expectedErr error
	}{
		{name: "WithIndexNullSourceThrowsNullArgumentException",
			source: nil,
			args: args{predicate: func(x, index int) bool { return x > 5 }},
			wantErr: true,
			expectedErr: ErrNilSource,
		},
		{name: "WithIndexNullPredicateThrowsNullArgumentException",
			source: NewOnSlice(1, 3, 7, 9, 10),
			args: args{predicate: nil},
			wantErr: true,
			expectedErr: ErrNilPredicate,
		},
	}
	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			got, err := WhereIdx(tt.source, tt.args.predicate)
			if (err != nil) != tt.wantErr {
				t.Errorf("WhereIdx() error = '%v', wantErr '%v'", err, tt.wantErr)
				return
			}
			if tt.wantErr {
				if err != tt.expectedErr {
					t.Errorf("WhereIdx() error = '%v', expectedErr '%v'", err, tt.expectedErr)
				}
				return
			}
			if !SequenceEqualMust(got, tt.want) {
				got.Reset()
				tt.want.Reset()
				t.Errorf("WhereIdx() = '%v', want '%v'", String(got), String(tt.want))
			}
		})
	}
}

func Test_WhereIdxMust_int(t *testing.T) {
	type args struct {
		predicate func(int, int) bool
	}
	tests := []struct {
		name string
		source Enumerator[int]
		args args
		want Enumerator[int]
	}{
		{name: "WithIndexSimpleFiltering",
			source: NewOnSlice(1, 3, 4, 2, 8, 1),
			args: args{predicate: func(x, index int) bool { return x < index }},
			want: NewOnSlice(2, 1),
		},
		{name: "WithIndexEmptySource",
			source: Empty[int](),
			args: args{predicate: func(x, index int) bool { return x < 4 }},
			want: Empty[int](),
		},
	}
	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			if got := WhereIdxMust(tt.source, tt.args.predicate); !SequenceEqualMust(got, tt.want) {
				got.Reset()
				tt.want.Reset()
				t.Errorf("WhereIdxMust() = '%v', want '%v'", String(got), String(tt.want))
			}
		})
	}
}

func Test_WhereIdxMust_string(t *testing.T) {
	type args struct {
		predicate func(string, int) bool
	}
	tests := []struct {
		name string
		source Enumerator[string]
		args args
		want Enumerator[string]
	}{
		{name: "1",
			source: NewOnSlice("one", "two", "three", "four", "five"),
			args: args{predicate: func(s string, i int) bool { return len(s) == i }},
			want: NewOnSlice("five"),
		},
	}
	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			if got := WhereIdxMust(tt.source, tt.args.predicate); !SequenceEqualMust(got, tt.want) {
				got.Reset()
				tt.want.Reset()
				t.Errorf("WhereIdxMust() = '%v', want '%v'", String(got), String(tt.want))
			}
		})
	}
}
