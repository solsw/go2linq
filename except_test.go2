func Test_ExceptCmpSelfMust_int(t *testing.T) {
	i4 := NewOnSlice(1, 2, 3, 4)
	type args struct {
		second Enumerator[int]
		cmp Comparer[int]
	}
	tests := []struct {
		name string
		first Enumerator[int]
		args args
		want Enumerator[int]
	}{
		{name: "SameEnumerable",
			first: i4,
			args: args{
				second: SkipMust(i4, 2),
				cmp: IntComparer,
			},
			want: NewOnSlice(1, 2)},
	}
	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			if got := ExceptCmpSelfMust(tt.first, tt.args.second, tt.args.cmp); !SequenceEqualMust(got, tt.want) {
				got.Reset()
				tt.want.Reset()
				t.Errorf("ExceptCmpSelfMust() = '%v', want '%v'", String(got), String(tt.want))
			}
		})
	}
}
