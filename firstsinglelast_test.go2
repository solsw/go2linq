					t.Errorf("SinglePred() error = '%v', expectedErr '%v'", err, tt.expectedErr)
				}
				return
			}
			if !reflect.DeepEqual(got, tt.want) {
				t.Errorf("SinglePred() = '%v', want '%v'", got, tt.want)
			}
		})
	}
}

