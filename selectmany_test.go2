package go2linq

import (
	"fmt"
	"testing"
)

// https://github.com/jskeet/edulinq/blob/master/src/Edulinq.Tests/SelectManyTest.cs

func Test_SelectManyMust_int_rune(t *testing.T) {
	type args struct {
		selector func(int) Enumerator[rune]
	}
	tests := []struct {
		name string
		source Enumerator[int]
		args args
		want Enumerator[rune]
	}{
		{name: "SimpleFlatten", source: NewOnSlice(3, 5, 20, 15),
			args: args{selector: func(x int) Enumerator[rune] {
				return NewOnSlice([]rune(fmt.Sprint(x))...)
			}},
			want: NewOnSlice('3', '5', '2', '0', '1', '5'),
		},
	}
	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			if got := SelectManyMust(tt.source, tt.args.selector); !SequenceEqualMust(got, tt.want) {
				got.Reset()
				tt.want.Reset()
				t.Errorf("SelectManyMust() = '%v', want '%v'", String(got), String(tt.want))
			}
		})
	}
}

func Test_SelectManyMust_int_int(t *testing.T) {
	type args struct {
		selector func(int) Enumerator[int]
	}
	tests := []struct {
		name string
		source Enumerator[int]
		args args
		want Enumerator[int]
	}{
		{name: "1", source: NewOnSlice(1, 2, 3, 4),
			args: args{selector: func(i int) Enumerator[int] {
				return NewOnSlice(i, i*i)
			}},
			want: NewOnSlice(1, 1, 2, 4, 3, 9, 4, 16),
		},
		{name: "2", source: NewOnSlice(1, 2, 3, 4),
			args: args{selector: func(i int) Enumerator[int] {
				if i%2 == 0 {
					return Empty[int]()
				}
				return NewOnSlice(i, i*i)
			}},
			want: NewOnSlice(1, 1, 3, 9),
		},
	}
	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			if got := SelectManyMust(tt.source, tt.args.selector); !SequenceEqualMust(got, tt.want) {
				got.Reset()
				tt.want.Reset()
				t.Errorf("SelectManyMust() = '%v', want '%v'", String(got), String(tt.want))
			}
		})
	}
}

