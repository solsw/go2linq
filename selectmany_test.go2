	tests := []struct {
		name string
		source Enumerator[int]
		args args
		want Enumerator[rune]
	}{
		{name: "SimpleFlattenWithIndex", source: NewOnSlice(3, 5, 20, 15),
			args: args{selector: func(x, index int) Enumerator[rune] {
				return NewOnSlice([]rune(fmt.Sprint(x + index))...)
			}},
			want: NewOnSlice('3', '6', '2', '2', '1', '8'),
