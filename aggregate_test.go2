package go2linq

import (
	"fmt"
	"reflect"
	"testing"
)

// https://github.com/jskeet/edulinq/blob/master/src/Edulinq.Tests/AggregateTest.cs

func Test_Aggregate_int(t *testing.T) {
	type args struct {
		accumulator func(int, int) int
	}
	tests := []struct {
		name string
		source Enumerator[int]
		args args
		want int
		wantErr bool
		expectedErr error
	}{
		{name: "NullSourceUnseeded",
			args: args{accumulator: func(x, y int) int { return x + y }},
			wantErr: true,
			expectedErr: ErrNilSource,
		},
		{name: "NullFuncUnseeded",
			source: NewOnSlice(1, 3),
			wantErr: true,
			expectedErr: ErrNilAccumulator,
		},
		{name: "UnseededAggregation",
			source: NewOnSlice(1, 4, 5),
			args: args{accumulator: func(current, value int) int { return current * 2 + value }},
			want: 17,
		},
		{name: "EmptySequenceUnseeded",
			source: Empty[int](),
			args: args{accumulator: func(ac, el int) int { return ac + el }},
			wantErr: true,
			expectedErr: ErrEmptySource,
		},
	}
	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			got, err := Aggregate(tt.source, tt.args.accumulator)
			if (err != nil) != tt.wantErr {
				t.Errorf("Aggregate() error = '%v', wantErr '%v'", err, tt.wantErr)
				return
			}
			if tt.wantErr {
				if err != tt.expectedErr {
					t.Errorf("Aggregate() error = '%v', expectedErr '%v'", err, tt.expectedErr)
				}
				return
			}
			if !reflect.DeepEqual(got, tt.want) {
				t.Errorf("Aggregate() = '%v', want '%v'", got, tt.want)
			}
		})
	}
}

func Test_AggregateMust_int(t *testing.T) {
	type args struct {
		accumulator func(int, int) int
	}
	tests := []struct {
		name string
		source Enumerator[int]
		args args
		want int
	}{
		{name: "UnseededSingleElementAggregation",
			source: NewOnSlice(1),
			args: args{accumulator: func(ac, el int) int { return ac * 2 + el }},
			want: 1,
		},
		{name: "FirstElementOfInputIsUsedAsSeedForUnseededOverload",
			source: NewOnSlice(5, 3, 2),
			args: args{accumulator: func(ac, el int) int { return ac * el }},
			want: 30,
		},
	}
	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			if got := AggregateMust(tt.source, tt.args.accumulator); !reflect.DeepEqual(got, tt.want) {
				t.Errorf("AggregateMust() = '%v', want '%v'", got, tt.want)
			}
		})
	}
}

func Test_AggregateSeed_int(t *testing.T) {
	type args struct {
		seed int
		accumulator func(int, int) int
	}
	tests := []struct {
		name string
		source Enumerator[int]
		args args
		want int
		wantErr bool
		expectedErr error
	}{
		{name: "NullSourceSeeded",
			args: args{accumulator: func(x, y int) int { return x + y }},
			wantErr: true,
			expectedErr: ErrNilSource,
		},
		{name: "NullFuncSeeded",
			source: NewOnSlice(1, 3),
			args: args{seed: 5},
			wantErr: true, expectedErr: ErrNilAccumulator,
		},
		{name: "SeededAggregation",
			source: NewOnSlice(1, 4, 5),
			args: args{seed: 5, accumulator: func(current, value int) int { return current * 2 + value }},
			want: 57,
		},
		{name: "EmptySequenceSeeded",
			source: Empty[int](),
			args: args{seed: 5, accumulator: func(x, y int) int { return x + y }},
			want: 5},
	}
	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			got, err := AggregateSeed(tt.source, tt.args.seed, tt.args.accumulator)
			if (err != nil) != tt.wantErr {
				t.Errorf("AggregateSeed() error = '%v', wantErr '%v'", err, tt.wantErr)
				return
			}
			if tt.wantErr {
				if err != tt.expectedErr {
					t.Errorf("AggregateSeed() error = '%v', expectedErr '%v'", err, tt.expectedErr)
				}
				return
			}
			if !reflect.DeepEqual(got, tt.want) {
				t.Errorf("AggregateSeedr() = '%v', want '%v'", got, tt.want)
			}
		})
	}
}

func Test_AggregateSeedMust_int32_int64(t *testing.T) {
	type args struct {
		seed int64
		accumulator func(int64, int32) int64
	}
	tests := []struct {
		name string
		source Enumerator[int32]
		args args
		want int64
	}{
		{name: "DifferentSourceAndAccumulatorTypes",
			source: NewOnSlice(int32(2000000000), int32(2000000000), int32(2000000000)),
			args: args{
				seed: int64(0),
				accumulator: func(ac int64, el int32) int64 { return ac + int64(el) },
			},
			want: int64(6000000000),
		},
	}
	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			if got := AggregateSeedMust(tt.source, tt.args.seed, tt.args.accumulator); !reflect.DeepEqual(got, tt.want) {
				t.Errorf("AggregateSeedMust() = '%v', want '%v'", got, tt.want)
			}
		})
	}
}

func Test_AggregateSeedSel_int_string(t *testing.T) {
	type args struct {
		seed int
		accumulator func(int, int) int
		resultSelector func(int) string
	}
	tests := []struct {
		name string
		source Enumerator[int]
		args args
		want string
		wantErr bool
		expectedErr error
	}{
		{name: "NullSourceSeededWithResultSelector",
			args: args{
				seed: 5,
				accumulator: func(x, y int) int { return x + y },
				resultSelector: func(result int) string { return fmt.Sprint(result) },
			},
			wantErr: true,
			expectedErr: ErrNilSource,
		},
		{name: "NullFuncSeededWithResultSelector",
			source: NewOnSlice(1, 3),
			args: args{
				seed: 5,
				resultSelector: func(result int) string { return fmt.Sprint(result) },
			},
			wantErr: true,
			expectedErr: ErrNilAccumulator,
		},
		{name: "NullProjectionSeededWithResultSelector",
			source: NewOnSlice(1, 3),
			args: args{
				seed: 5,
				accumulator: func(x, y int) int { return x + y },
			},
			wantErr: true,
			expectedErr: ErrNilSelector,
		},
		{name: "SeededAggregationWithResultSelector",
			source: NewOnSlice(1, 4, 5),
			args: args{
				seed: 5,
				accumulator: func(current, value int) int { return current * 2 + value },
				resultSelector: func(result int) string { return fmt.Sprint(result) },
			},
			want: "57",
		},
		{name: "EmptySequenceSeededWithResultSelector",
			source: Empty[int](),
			args: args{
				seed: 5,
				accumulator: func(x, y int) int { return x + y },
				resultSelector: func(result int) string { return fmt.Sprint(result) },
			},
			want: "5",
		},
	}
	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			got, err := AggregateSeedSel(tt.source, tt.args.seed, tt.args.accumulator, tt.args.resultSelector)
			if (err != nil) != tt.wantErr {
				t.Errorf("AggregateSeedSel() error = '%v', wantErr '%v'", err, tt.wantErr)
				return
			}
			if tt.wantErr {
				if err != tt.expectedErr {
					t.Errorf("AggregateSeedSel() error = '%v', expectedErr '%v'", err, tt.expectedErr)
				}
				return
			}
			if !reflect.DeepEqual(got, tt.want) {
				t.Errorf("AggregateSeedSel() = '%v', want '%v'", got, tt.want)
			}
		})
	}
}
