	}
	tests := []struct {
		name string
		first Enumerator[string]
		args args
		want Enumerator[string]
	}{
		{name: "UnionWithCaseInsensitiveComparerEq",
			first: NewOnSlice("a", "b", "B", "c", "b"),
			args: args{
				second: NewOnSlice("d", "e", "d", "a"),
				eq: CaseInsensitiveEqualer,
