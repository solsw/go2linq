func Test_DistinctCmpMust_string(t *testing.T) {
	type args struct {
		cmp Comparer[string]
	}
	tests := []struct {
		name string
		source Enumerator[string]
		args args
		want Enumerator[string]
	}{
		{name: "DistinctStringsWithCaseInsensitiveComparer",
			source: NewOnSlice("xyz", testString1, "XYZ", testString2, "def"),
			args: args{cmp: CaseInsensitiveComparer},
			want: NewOnSlice("xyz", testString1, "def"),
		},
		{name: "3",
			source: NewOnSlice("A", "a", "b", "c", "b"),
			args: args{cmp: CaseInsensitiveComparer},
			want: NewOnSlice("A", "b", "c"),
		},
		{name: "4",
			source: NewOnSlice("b", "a", "d", "a"),
			args: args{cmp: CaseInsensitiveComparer},
			want: NewOnSlice("b", "a", "d"),
		},
	}
	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			if got := DistinctCmpMust(tt.source, tt.args.cmp); !SequenceEqualMust(got, tt.want) {
				got.Reset()
				tt.want.Reset()
				t.Errorf("DistinctCmpMust() = '%v', want '%v'", String(got), String(tt.want))
			}
		})
	}
}

func Test_DistinctCmpMust_int(t *testing.T) {
	type args struct {
		cmp Comparer[int]
	}
	tests := []struct {
		name string
		source Enumerator[int]
		args args
		want Enumerator[int]
	}{
		{name: "EmptyEnumerable",
			source: Empty[int](),
			args: args{cmp: IntComparer},
			want: Empty[int](),
		},
		{name: "1",
			source: NewOnSlice(1, 2, 3, 4),
			args: args{cmp: IntComparer},
			want: NewOnSlice(1, 2, 3, 4),
		},
		{name: "2",
			source: ConcatMust(NewOnSlice(1, 2, 3, 4), NewOnSlice(1, 2, 3, 4)),
			args: args{cmp: IntComparer},
			want: NewOnSlice(1, 2, 3, 4),
		},
	}
	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			if got := DistinctCmpMust(tt.source, tt.args.cmp); !SequenceEqualMust(got, tt.want) {
				got.Reset()
				tt.want.Reset()
				t.Errorf("DistinctCmpMust() = '%v', want '%v'", String(got), String(tt.want))
			}
		})
	}
}

func Test_DistinctEq_Reset(t *testing.T) {
	source := DistinctEqMust(
		NewOnSlice("xyz", testString1, "XYZ", testString2, "def"),
		CaseInsensitiveEqualityComparer)
	got1 := NewOnSlice(Slice(source)...)
	source.Reset()
	got2 := NewOnSlice(Slice(source)...)
	if !SequenceEqualMust(got1, got2) {
		got1.Reset()
		got2.Reset()
		t.Errorf("Reset error: '%v' != '%v'", String(got1), String(got2))
	}
}
