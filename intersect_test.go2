func Test_IntersectCmpSelfMust(t *testing.T) {
	e1 := NewOnSlice(4, 3, 2, 1)
	e2 := NewOnSlice(1, 2, 3, 4)
	e3 := NewOnSlice(1, 2, 3, 4)
	type args struct {
		second Enumerator[int]
		cmp Comparer[int]
	}
	tests := []struct {
		name string
		first Enumerator[int]
		args args
		want Enumerator[int]
	}{
		{name: "SameEnumerable1",
			first: e1,
			args: args{
				second: e1,
				cmp: IntComparer,
			},
			want: NewOnSlice(4, 3, 2, 1),
		},
		{name: "SameEnumerable2",
			first: e2,
			args: args{
				second: SkipMust(e2, 1),
				cmp: IntComparer,
			},
			want: NewOnSlice(2, 3, 4),
		},
		{name: "SameEnumerable3",
			first: SkipMust(e3, 3),
			args: args{
				second: e3,
				cmp: IntComparer,
			},
			want: NewOnSlice(4),
		},
	}
	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			if got := IntersectCmpSelfMust(tt.first, tt.args.second, tt.args.cmp); !SequenceEqualMust(got, tt.want) {
				got.Reset()
				tt.want.Reset()
				t.Errorf("IntersectCmpSelfMust() = '%v', want '%v'", String(got), String(tt.want))
			}
		})
	}
}
